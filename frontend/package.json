{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "lint:staged": "lint-staged",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:components": "vitest run tests/components",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b --pretty false",
    "audit": "bun audit --audit-level high",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,svelte}": [
      "prettier --write",
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/svelte": "^5.2.9",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.5.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.3",
    "tailwindcss": "^4.2.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tabler/icons-svelte": "^3.41.1",
    "@wailsapp/runtime": "^1.1.1",
    "@wailsio/runtime": "^3.0.0-alpha.79",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-svelte": "^1.0.1",
    "simple-icons": "^16.24.0",
    "zod": "^4.3.6"
  }
}
